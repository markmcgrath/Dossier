#!/usr/bin/env bash
# dossier-lint-hook — PostToolUse hook wrapper for dossier-lint
#
# Called by hooks.json after a Write tool call. Reads the tool output
# from stdin (JSON), extracts the file_path, and runs dossier-lint on it.
# Only lints files inside vault artifact folders.
#
# Exit codes (per Claude Code hook spec):
#   0 — No issues found (hook proceeds silently)
#   2 — PII found — blocks and shows warning to user
#   Other — Non-blocking error (ignored by Claude Code)

set -euo pipefail

VAULT_DIRS=("evals/" "outreach/" "cover-letters/" "interview-prep/" "research/" "daily/" "weekly/")

# Read hook input from stdin
HOOK_INPUT=$(cat)

# Extract file_path from tool_input
FILE_PATH=$(echo "$HOOK_INPUT" | python3 -c "
import sys, json
try:
    data = json.load(sys.stdin)
    # tool_input is nested under tool_input key in PostToolUse events
    tool_input = data.get('tool_input', data)
    print(tool_input.get('file_path', ''))
except Exception:
    print('')
" 2>/dev/null || true)

if [[ -z "$FILE_PATH" ]]; then
  exit 0
fi

# Only lint vault artifact files
IS_VAULT_FILE=0
for dir in "${VAULT_DIRS[@]}"; do
  if [[ "$FILE_PATH" == *"$dir"* ]]; then
    IS_VAULT_FILE=1
    break
  fi
done

if [[ "$IS_VAULT_FILE" -eq 0 ]]; then
  exit 0
fi

if [[ ! -f "$FILE_PATH" ]]; then
  exit 0
fi

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

if "$SCRIPT_DIR/dossier-lint" --check-pii "$FILE_PATH"; then
  exit 0
else
  # Exit 2 = blocking error per Claude Code hook spec
  # stderr is shown to user
  echo "dossier-lint: PII detected in $FILE_PATH — review before saving." >&2
  exit 2
fi
