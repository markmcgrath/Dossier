#!/usr/bin/env bash
# dossier-lint — PII scanner for Dossier vault artifacts
#
# Usage:
#   dossier-lint --check-pii <filepath>
#   dossier-lint --check-pii <filepath> [--deny-list <deny-list-file>]
#
# Exit codes:
#   0 — No PII found
#   1 — PII found (matches printed to stderr)
#   2 — Usage error or file not found

set -euo pipefail

MODE=""
FILE=""
DENY_LIST=""

# Parse arguments
while [[ $# -gt 0 ]]; do
  case "$1" in
    --check-pii)
      MODE="check-pii"
      FILE="${2:-}"
      shift 2
      ;;
    --deny-list)
      DENY_LIST="${2:-}"
      shift 2
      ;;
    *)
      echo "Unknown argument: $1" >&2
      exit 2
      ;;
  esac
done

if [[ "$MODE" != "check-pii" ]]; then
  echo "Usage: dossier-lint --check-pii <filepath> [--deny-list <deny-list-file>]" >&2
  exit 2
fi

if [[ -z "$FILE" ]]; then
  echo "Error: no file path provided" >&2
  exit 2
fi

if [[ ! -f "$FILE" ]]; then
  echo "Error: file not found: $FILE" >&2
  exit 2
fi

FOUND=0
MATCHES=""

# Pattern 1: Email addresses
EMAIL_MATCHES=$(grep -nE '\b[A-Za-z0-9._%+\-]+@[A-Za-z0-9.\-]+\.[A-Za-z]{2,}\b' "$FILE" 2>/dev/null || true)
if [[ -n "$EMAIL_MATCHES" ]]; then
  FOUND=1
  MATCHES+="[EMAIL] $EMAIL_MATCHES"$'\n'
fi

# Pattern 2: US phone numbers (dashed, parenthesized, or continuous 10-digit formats)
PHONE_MATCHES=$(grep -nE '\b(\+1[[:space:].-]?)?\(?[0-9]{3}\)?[[:space:].-]?[0-9]{3}[[:space:].-]?[0-9]{4}\b' "$FILE" 2>/dev/null || true)
if [[ -n "$PHONE_MATCHES" ]]; then
  FOUND=1
  MATCHES+="[PHONE] $PHONE_MATCHES"$'\n'
fi

# Pattern 3: SSN-like patterns
SSN_MATCHES=$(grep -nE '\b[0-9]{3}-[0-9]{2}-[0-9]{4}\b' "$FILE" 2>/dev/null || true)
if [[ -n "$SSN_MATCHES" ]]; then
  FOUND=1
  MATCHES+="[SSN] $SSN_MATCHES"$'\n'
fi

# Pattern 4: Notion UUIDs (32-hex or 8-4-4-4-12 format)
NOTION_MATCHES=$(grep -nE '\b[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}\b' "$FILE" 2>/dev/null || true)
if [[ -n "$NOTION_MATCHES" ]]; then
  FOUND=1
  MATCHES+="[UUID/NOTION-ID] $NOTION_MATCHES"$'\n'
fi

# Pattern 5: Custom deny-list
if [[ -n "$DENY_LIST" && -f "$DENY_LIST" ]]; then
  while IFS= read -r pattern; do
    [[ -z "$pattern" || "$pattern" == \#* ]] && continue
    DENY_MATCHES=$(grep -nF "$pattern" "$FILE" 2>/dev/null || true)
    if [[ -n "$DENY_MATCHES" ]]; then
      FOUND=1
      MATCHES+="[DENY-LIST:$pattern] $DENY_MATCHES"$'\n'
    fi
  done < "$DENY_LIST"
fi

if [[ "$FOUND" -eq 1 ]]; then
  echo "dossier-lint: PII detected in $FILE" >&2
  echo "$MATCHES" >&2
  exit 1
fi

exit 0
